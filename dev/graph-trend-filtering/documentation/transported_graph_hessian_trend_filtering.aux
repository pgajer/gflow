\@writefile{toc}{\contentsline {subsection}{\numberline {5.2}Edge-Angle Riemannian Graph Matching}{4}{subsection.5.2}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.3}Local Embedding Soft Transport}{5}{subsection.5.3}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {5.4}Adaptive Local Transport Thresholding}{6}{subsection.5.4}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Local quantile rule.}{6}{section*.1}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Local robust-\(z\) rule.}{6}{section*.2}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Entropy-fraction rule.}{7}{section*.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Adaptive local thresholding for transported direction matching. The top neighborhood has one clearly best candidate, a large margin, and a sharp softmax distribution; it is accepted. The bottom neighborhood has several nearly tied candidates and diffuse softmax mass; it is rejected by local quantile, robust-\(z\), or entropy-fraction gates.}}{7}{figure.4}\protected@file@percent }
\newlabel{fig:adaptive-local-transport-thresholding}{{4}{7}{Adaptive local thresholding for transported direction matching. The top neighborhood has one clearly best candidate, a large margin, and a sharp softmax distribution; it is accepted. The bottom neighborhood has several nearly tied candidates and diffuse softmax mass; it is rejected by local quantile, robust-\(z\), or entropy-fraction gates}{figure.4}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.5}Status of the Adaptive-Threshold Calibration Experiment}{8}{subsection.5.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Summary of the adaptive-threshold calibration sweep. Adaptive gates can reduce residuals, but the reduction often comes with substantial row loss. The fixed angle/length rule remains the safest broad baseline under the \(50\%\) row-retention constraint.}}{8}{figure.5}\protected@file@percent }
\newlabel{fig:adaptive-threshold-calibration-summary}{{5}{8}{Summary of the adaptive-threshold calibration sweep. Adaptive gates can reduce residuals, but the reduction often comes with substantial row loss. The fixed angle/length rule remains the safest broad baseline under the \(50\%\) row-retention constraint}{figure.5}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {5.6}Approximate Parallelogram Transport}{8}{subsection.5.6}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Approximate parallelogram transport matches edge directions by asking whether the four vertices close a parallelogram. On generic sparse graphs, an ambient or local-embedding score is often more practical than a pure graph-distance score.}}{9}{figure.6}\protected@file@percent }
