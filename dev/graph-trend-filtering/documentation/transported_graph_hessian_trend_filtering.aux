\@writefile{toc}{\contentsline {section}{\numberline {2}Metric Graphs, Darts, and Directional Fibers}{1}{section.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces The first-difference fiber at a vertex is the collection of length-normalized outgoing differences. It is the discrete object that plays the role of a local directional gradient.}}{2}{figure.1}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {3}Why Raw All-Pairs Fiber Differences Are Too Strong}{2}{section.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces On a grid, all-pairs fiber comparison mixes unrelated directions. For \(f(i,j)=i\), comparing a \(y\)-direction derivative with an \(x\)-direction derivative produces a nonzero second difference even though \(f\) is affine.}}{3}{figure.2}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {4}The Abstract Transported Graph Hessian}{3}{section.4}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {5}Direction-Matching and Parallel-Transport Rules}{3}{section.5}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces The transported Hessian compares outgoing directional derivatives after a direction at \(u'\) has been matched or transported to a direction at \(u\). The transport matrix is the extra structure missing from an edge-length only graph.}}{4}{figure.3}\protected@file@percent }
